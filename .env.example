# Database Configuration (PostgreSQL)
# If PostgreSQL is running on the host/another container:
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=db_password
DB_NAME=nokkinokk

# Cache Configuration (Redis)
# If Redis is running on the host/another container:
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Server Settings
PORT=5000
NODE_ENV=production
UPLOAD_DIR=./uploads
